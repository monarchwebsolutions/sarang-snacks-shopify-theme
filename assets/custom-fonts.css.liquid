/* Google Fonts: Outfit & Inter (All Weights + Italic) */
@import url('https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,100..900;1,100..900&family=Outfit:ital,wght@0,100..900;1,100..900&display=swap');

@font-face {
  font-family: 'Nicko';
  src: url("{{ 'nicko.woff2' | asset_url }}") format('woff2'),
       url("{{ 'nicko.woff' | asset_url }}") format('woff');
  font-style: normal;
  font-weight: 400;
  font-display: swap;
}

.font-nicko {
  font-family: 'Nicko', sans-serif;
}

@font-face {
  font-family: 'Redmarsh';
  src: url("{{ 'redmarsh.woff' | asset_url }}") format('woff');
  font-style: normal;
  font-weight: 400;
  font-display: swap;
}

.font-redmarsh {
  font-family: 'Redmarsh', sans-serif;
}
