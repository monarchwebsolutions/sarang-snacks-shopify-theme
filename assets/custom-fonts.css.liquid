/* Google Fonts: Outfit, Inter, and Manrope */
@import url('https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,100..900;1,100..900&family=Manrope:wght@200..800&family=Outfit:ital,wght@0,100..900;1,100..900&display=swap');

@font-face {
  font-family: 'Nicko';
  src: url("{{ 'nicko.woff2' | asset_url }}") format('woff2'),
       url("{{ 'nicko.woff' | asset_url }}") format('woff');
  font-style: normal;
  font-weight: 400;
  font-display: swap;
}

.font-nicko {
  font-family: 'Nicko', sans-serif;
}

.font-manrope {
  font-family: 'Manrope', sans-serif;
  font-weight: 600;
}
