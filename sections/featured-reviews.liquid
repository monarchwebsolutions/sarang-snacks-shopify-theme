    {
      "type": "range",
      "id": "review_title_size_mobile",
      "min": 16,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Review title size mobile",
      "default": 22
    },
    {
      "type": "range",
      "id": "review_title_size_desktop",
      "min": 16,
      "max": 56,
      "step": 1,
      "unit": "px",
      "label": "Review title size desktop",
      "default": 24
