{%- liquid
  assign review_blocks = section.blocks | where: 'type', 'review'
  assign reviews_count = review_blocks.size
  assign enable_slider = false
  if section.settings.review_layout != 'grid' and reviews_count > 1
    assign enable_slider = true
  endif

  assign desktop_columns_class = 'lg:grid-cols-3'
  case section.settings.desktop_columns
    when '1'
      assign desktop_columns_class = 'lg:grid-cols-1'
    when '2'
      assign desktop_columns_class = 'lg:grid-cols-2'
    when '3'
      assign desktop_columns_class = 'lg:grid-cols-3'
    when '4'
      assign desktop_columns_class = 'lg:grid-cols-4'
  endcase

  assign card_text_override_enabled = section.settings.enable_review_card_text_override
  assign card_background_override_enabled = section.settings.enable_review_card_background_override
-%}

<section
  class="relative overflow-hidden bg-scheme-background text-scheme-text {% if section.settings.use_gradient_background %}bg-scheme-gradient{% endif %}"
  data-color-scheme="{{ section.settings.color_scheme }}"
>
  <div class="section-content px-section py-section-vertical-spacing">
    <div class="mx-auto max-w-site {{ section.settings.content_width_desktop }} {% if section.settings.display_on_card %}card{% endif %}">
      <div class="{% if section.settings.display_on_card %}card__surface p-5 lg:p-10{% endif %} relative z-shape-divider mx-auto text-center">
        {% if section.settings.title != '' %}
          <h2 class="inline-heading-rte font-heading {{ section.settings.heading_size }} heading-style break-words {{ settings.heading_drop_shadow_style }}">
            {{ section.settings.title }}
          </h2>
        {% endif %}

        <div class="font-main {% if section.settings.title != '' %}mt-5{% endif %} rte mx-auto leading-snug">
          {{ section.settings.rich_text }}
        </div>

        {% if reviews_count > 0 %}
          <div class="featured-reviews__content mt-8 lg:mt-10">
            <div
              {% if enable_slider %}
                id="slideshow-{{ section.id }}"
                class="splide"
              {% endif %}
            >
              <div class="{% if enable_slider %}splide__track overflow-visible{% endif %}">
                <ul class="{% if enable_slider %}splide__list{% else %}grid grid-cols-1 gap-5 lg:gap-8 {{ desktop_columns_class }}{% endif %}">
                  {%- for block in review_blocks -%}
                    {%- capture reviewer_photo_sizes -%}(min-width: 990px) {{ section.settings.photo_size_desktop }}px, {{ section.settings.photo_size_mobile }}px{%- endcapture -%}
                    <li
                      class="{% if enable_slider %}splide__slide w-full {% if settings.card_shadow_direction contains 'top' %}pt-card-shadow{% else %}pb-card-shadow{% endif %}{% endif %}"
                      {{ block.shopify_attributes }}
                    >
                      <div class="featured-reviews__card text-left text-scheme-card-text card h-full">
                        <div class="featured-reviews__card-surface bg-scheme-card card__surface h-full p-5 lg:p-8">
                          {% if block.settings.reviewer_photo != blank %}
                            <div class="featured-reviews__photo-wrap mb-4">
                              {{
                                block.settings.reviewer_photo
                                | image_url: width: 320
                                | image_tag:
                                  class: 'featured-reviews__photo mx-auto rounded-full object-cover',
                                  loading: 'lazy',
                                  sizes: reviewer_photo_sizes
                              }}
                            </div>
                          {% endif %}

                          <div class="featured-reviews__meta text-center">
                            {% if block.settings.review_date != blank %}
                              <p class="featured-reviews__date mb-3">
                                {{ block.settings.review_date }}
                              </p>
                            {% endif %}

                            {% if block.settings.review_stars > 0 %}
                              <div class="featured-reviews__stars mb-4" aria-label="{{ block.settings.review_stars }} star review">
                                {%- for i in (1..block.settings.review_stars) -%}
                                  <span>★</span>
                                {%- endfor -%}
                              </div>
                            {% endif %}

                            {% if block.settings.review_title != blank %}
                              <h3 class="featured-reviews__title font-heading mb-3 break-words {{ settings.heading_drop_shadow_style }}">
                                {{ block.settings.review_title }}
                              </h3>
                            {% endif %}

                            {% if block.settings.review_text != blank %}
                              <div class="featured-reviews__text rte mx-auto leading-snug">
                                {{ block.settings.review_text }}
                              </div>
                            {% endif %}
                          </div>
                        </div>
                      </div>
                    </li>
                  {%- endfor -%}
                </ul>
              </div>

              {% if enable_slider %}
                <div class="splide__arrows mt-5 flex items-center justify-between px-section">
                  {%- render 'splide-navigation', autoplay: section.settings.review_layout == 'carousel' and section.settings.carousel_autoplay -%}
                </div>

                <script class="slideshow-options" type="application/json">
                  {
                    "mediaQuery": "min",
                    "arrows": true,
                    "pagination": false,
                    "type": "loop",
                    "rewind": true,
                    "gap": "24px",
                    "perPage": 1,
                    "perMove": 1,
                    "autoplay": {% if section.settings.review_layout == 'carousel' and section.settings.carousel_autoplay %}true{% else %}false{% endif %},
                    "interval": {{ section.settings.carousel_rotation_speed | times: 1000 | json }},
                    "pauseOnHover": true,
                    "pauseOnFocus": true,
                    "breakpoints": {
                      "990": {
                        "perPage": {{ section.settings.desktop_columns | plus: 0 | json }}
                      }
                    },
                    "autoScroll": {
                      "autoStart": {% if section.settings.review_layout == 'auto_slider' %}true{% else %}false{% endif %},
                      "speed": {% if section.settings.review_layout == 'auto_slider' %}{{ section.settings.auto_slider_speed | json }}{% else %}1{% endif %}
                    }
                  }
                </script>
              {% endif %}
            </div>
          </div>
        {% endif %}

        {%- if section.settings.button_link != blank and section.settings.button_label != '' -%}
          <div class="mt-5">
            <a
              href="{{ section.settings.button_link }}"
              class="push-btn inline-block"
            >
              <span class="push-btn__surface">
                {{- section.settings.button_label -}}
              </span>
            </a>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>

  <style>
    #shopify-section-{{ section.id }} .featured-reviews__photo {
      width: {{ section.settings.photo_size_mobile }}px;
      height: {{ section.settings.photo_size_mobile }}px;
    }

    #shopify-section-{{ section.id }} .featured-reviews__date {
      font-size: {{ section.settings.date_size_mobile }}px;
    }

    #shopify-section-{{ section.id }} .featured-reviews__stars {
      color: {{ section.settings.star_color }};
      font-size: {{ section.settings.star_size_mobile }}px;
      line-height: 1;
      letter-spacing: 2px;
    }

    #shopify-section-{{ section.id }} .featured-reviews__title {
      font-size: {{ section.settings.review_title_size_mobile }}px;
      line-height: 1.1;
    }

    #shopify-section-{{ section.id }} .featured-reviews__text,
    #shopify-section-{{ section.id }} .featured-reviews__text p {
      font-size: {{ section.settings.review_text_size_mobile }}px;
    }

    {% if card_text_override_enabled %}
      #shopify-section-{{ section.id }} .featured-reviews__card,
      #shopify-section-{{ section.id }} .featured-reviews__card h3,
      #shopify-section-{{ section.id }} .featured-reviews__card p,
      #shopify-section-{{ section.id }} .featured-reviews__card span,
      #shopify-section-{{ section.id }} .featured-reviews__card a,
      #shopify-section-{{ section.id }} .featured-reviews__card li {
        color: {{ section.settings.review_card_text_color }} !important;
      }
    {% endif %}

    {% if card_background_override_enabled %}
      #shopify-section-{{ section.id }} .featured-reviews__card-surface {
        background-color: {{ section.settings.review_card_background_color }} !important;
      }
    {% endif %}

    {% if section.settings.slider_button_background_color != blank %}
      #shopify-section-{{ section.id }} .controls .push-btn__surface {
        background-color: {{ section.settings.slider_button_background_color }} !important;
      }
    {% endif %}

    @media (min-width: 990px) {
      #shopify-section-{{ section.id }} .featured-reviews__photo {
        width: {{ section.settings.photo_size_desktop }}px;
        height: {{ section.settings.photo_size_desktop }}px;
      }

      #shopify-section-{{ section.id }} .featured-reviews__date {
        font-size: {{ section.settings.date_size_desktop }}px;
      }

      #shopify-section-{{ section.id }} .featured-reviews__stars {
        font-size: {{ section.settings.star_size_desktop }}px;
      }

      #shopify-section-{{ section.id }} .featured-reviews__title {
        font-size: {{ section.settings.review_title_size_desktop }}px;
      }

      #shopify-section-{{ section.id }} .featured-reviews__text,
      #shopify-section-{{ section.id }} .featured-reviews__text p {
        font-size: {{ section.settings.review_text_size_desktop }}px;
      }
    }
  </style>

  {%- liquid
    for block in section.blocks
      case block.type
        when 'background_shape'
          render 'block-background-shape', block: block
        when 'background_pattern'
          render 'block-background-pattern', block: block, scheme: section.settings.color_scheme
      endcase
    endfor
  -%}
</section>

{%- liquid
  assign stickers = section.blocks | where: 'type', 'sticker'
  assign shape_dividers = section.blocks | where: 'type', 'shape_divider'
  for sticker in stickers
    render 'block-sticker', block: sticker
  endfor
  for shape_divider in shape_dividers
    render 'block-shape-divider', block: shape_divider
  endfor
-%}

{% schema %}
{
  "name": "Featured reviews",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "t:common.settings.title.label",
      "default": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:common.settings.heading_size.label",
      "options": [
        {
          "value": "heading-standard",
          "label": "t:common.options.standard.label"
        },
        {
          "value": "heading-feature",
          "label": "t:common.options.feature.label"
        }
      ],
      "default": "heading-standard"
    },
    {
      "id": "rich_text",
      "type": "richtext",
      "label": "t:sections.rich_text.settings.rich_text.label",
      "default": "<p>Use this text to share information about your brand with your customers. Describe a product, share announcements, or welcome customers to your store.</p>"
    },
    {
      "type": "header",
      "content": "Reviews"
    },
    {
      "type": "select",
      "id": "review_layout",
      "label": "Review layout",
      "default": "carousel",
      "options": [
        {
          "value": "carousel",
          "label": "Carousel"
        },
        {
          "value": "auto_slider",
          "label": "Auto slider"
        },
        {
          "value": "grid",
          "label": "Grid"
        }
      ]
    },
    {
      "type": "select",
      "id": "desktop_columns",
      "label": "Desktop columns",
      "default": "3",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        },
        {
          "value": "3",
          "label": "3"
        },
        {
          "value": "4",
          "label": "4"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "carousel_autoplay",
      "label": "Auto-rotate carousel",
      "default": true
    },
    {
      "type": "range",
      "id": "carousel_rotation_speed",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Carousel rotation speed",
      "default": 5
    },
    {
      "type": "range",
      "id": "auto_slider_speed",
      "min": 1,
      "max": 5,
      "step": 1,
      "label": "Auto slider speed",
      "default": 2
    },
    {
      "type": "checkbox",
      "id": "display_on_card",
      "label": "t:common.settings.display_on_card.label"
    },
    {
      "type": "select",
      "id": "content_width_desktop",
      "label": "t:sections.rich_text.settings.content_width_desktop.label",
      "default": "lg:w-2/3",
      "options": [
        {
          "value": "lg:w-1/3",
          "label": "t:common.options.one_third.label"
        },
        {
          "value": "lg:w-1/2",
          "label": "t:common.options.one_half.label"
        },
        {
          "value": "lg:w-2/3",
          "label": "t:common.options.two_thirds.label"
        },
        {
          "value": "lg:w-full",
          "label": "t:common.options.full_width.label"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:common.settings.header_link"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:common.settings.button_link.label"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:common.settings.button_label.label",
      "default": "Shop Now"
    },
    {
      "type": "header",
      "content": "Review styling"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star color",
      "default": "#FFCC33"
    },
    {
      "type": "checkbox",
      "id": "enable_review_card_text_override",
      "label": "Override review card text color"
    },
    {
      "type": "color",
      "id": "review_card_text_color",
      "label": "Review card text color",
      "default": "#353B44"
    },
    {
      "type": "checkbox",
      "id": "enable_review_card_background_override",
      "label": "Override review card background color"
    },
    {
      "type": "color",
      "id": "review_card_background_color",
      "label": "Review card background color",
      "default": "#FBF9F6"
    },
    {
      "type": "color",
      "id": "slider_button_background_color",
      "label": "Slider button background color",
      "default": "#FBF9F6"
    },
    {
      "type": "header",
      "content": "Review sizing"
    },
    {
      "type": "range",
      "id": "photo_size_mobile",
      "min": 40,
      "max": 140,
      "step": 2,
      "unit": "px",
      "label": "Photo size mobile",
      "default": 72
    },
    {
      "type": "range",
      "id": "photo_size_desktop",
      "min": 40,
      "max": 180,
      "step": 2,
      "unit": "px",
      "label": "Photo size desktop",
      "default": 88
    },
    {
      "type": "range",
      "id": "date_size_mobile",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Review date size mobile",
      "default": 14
    },
    {
      "type": "range",
      "id": "date_size_desktop",
      "min": 10,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Review date size desktop",
      "default": 15
    },
    {
      "type": "range",
      "id": "star_size_mobile",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Star size mobile",
      "default": 18
    },
    {
      "type": "range",
      "id": "star_size_desktop",
      "min": 12,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Star size desktop",
      "default": 20
