{%- liquid
  assign slide_count = section.blocks.size
  assign show_arrows = false

  if slide_count > 1
    assign show_arrows = true
  endif
-%}

{%- if slide_count > 0 -%}
  <section
    id="shopify-section-{{ section.id }}-announcement-bar"
    class="announcement-bar"
    style="
      --announcement-bar-background: {{ section.settings.background_color }};
      --announcement-bar-foreground: {{ section.settings.foreground_color }};
      --announcement-bar-font-size-mobile: {{ section.settings.font_size_mobile }}px;
      --announcement-bar-font-size-desktop: {{ section.settings.font_size_desktop }}px;
      --announcement-bar-font-weight: {{ section.settings.font_weight }};
      --announcement-bar-height-mobile: {{ section.settings.bar_height_mobile }}px;
      --announcement-bar-height-desktop: {{ section.settings.bar_height_desktop }}px;
      --announcement-bar-arrow-weight: {{ section.settings.arrow_weight }};
      --announcement-bar-arrow-size-mobile: {{ section.settings.arrow_size_mobile }}px;
      --announcement-bar-arrow-size-desktop: {{ section.settings.arrow_size_desktop }}px;
    "
  >
    {%- if show_arrows -%}
      <div
        id="announcement-bar-slider-{{ section.id }}"
        class="splide [&:not(.is-initialized)]:visible announcement-bar__slider"
      >
        <div class="announcement-bar__inner">
          <div class="splide__arrows announcement-bar__arrows">
            <button
              class="splide__arrow splide__arrow--prev announcement-bar__arrow"
              type="button"
            >
              <span class="sr-only">Previous announcement</span>
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M20 12H6" stroke="currentColor" stroke-width="{{ section.settings.arrow_weight }}" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M11 5L4 12L11 19" stroke="currentColor" stroke-width="{{ section.settings.arrow_weight }}" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>

          <div class="splide__track announcement-bar__track">
            <ul class="splide__list">
              {%- for block in section.blocks -%}
                <li
                  class="splide__slide announcement-bar__slide"
                  {{ block.shopify_attributes }}
                >
                  <div class="announcement-bar__content rte">
                    {{ block.settings.content }}
                  </div>
                </li>
              {%- endfor -%}
            </ul>
          </div>

          <div class="splide__arrows announcement-bar__arrows">
            <button
              class="splide__arrow splide__arrow--next announcement-bar__arrow"
              type="button"
            >
              <span class="sr-only">Next announcement</span>
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M4 12H18" stroke="currentColor" stroke-width="{{ section.settings.arrow_weight }}" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M13 5L20 12L13 19" stroke="currentColor" stroke-width="{{ section.settings.arrow_weight }}" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        </div>

        <script class="slideshow-options" type="application/json">
          {
            "mediaQuery": "min",
            "type": "slide",
            "perPage": 1,
            "perMove": 1,
            "autoWidth": false,
            "pagination": false,
            "arrows": true,
            "rewind": true,
            "drag": true,
            "speed": 500,
            "gap": "0px",
            "autoHeight": true,
            "autoplay": {{ section.settings.auto_rotate | json }},
            "interval": {{ section.settings.auto_rotate_interval | times: 1000 }},
            "pauseOnHover": true,
            "pauseOnFocus": true,
            "resetProgress": false
          }
        </script>
      </div>
    {%- else -%}
      <div class="announcement-bar__inner announcement-bar__inner--single">
        <div class="announcement-bar__content rte">
          {{ section.blocks.first.settings.content }}
        </div>
      </div>
    {%- endif -%}
  </section>

  <style>
    #shopify-section-{{ section.id }}-announcement-bar {
      background: var(--announcement-bar-background);
      color: var(--announcement-bar-foreground);
      border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    }

    #shopify-section-{{ section.id }}-announcement-bar .announcement-bar__inner {
      display: flex;
      align-items: center;
      gap: 12px;
      min-height: var(--announcement-bar-height-mobile);
      padding: 8px 16px;
    }

    #shopify-section-{{ section.id }}-announcement-bar .announcement-bar__inner--single {
      justify-content: center;
    }

    #shopify-section-{{ section.id }}-announcement-bar .announcement-bar__track {
      flex: 1 1 auto;
      min-width: 0;
    }

    #shopify-section-{{ section.id }}-announcement-bar .announcement-bar__arrows {
      display: flex;
      align-items: center;
      flex: 0 0 auto;
    }

    #shopify-section-{{ section.id }}-announcement-bar .announcement-bar__slide {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    #shopify-section-{{ section.id }}-announcement-bar .announcement-bar__content {
      width: 100%;
      text-align: center;
      font-size: var(--announcement-bar-font-size-mobile);
      font-weight: var(--announcement-bar-font-weight);
      line-height: 1.3;
      color: var(--announcement-bar-foreground);
    }

    #shopify-section-{{ section.id }}-announcement-bar .announcement-bar__content p,
    #shopify-section-{{ section.id }}-announcement-bar .announcement-bar__content a,
    #shopify-section-{{ section.id }}-announcement-bar .announcement-bar__content span,
    #shopify-section-{{ section.id }}-announcement-bar .announcement-bar__content strong,
    #shopify-section-{{ section.id }}-announcement-bar .announcement-bar__content em {
      color: inherit;
    }

    #shopify-section-{{ section.id }}-announcement-bar .announcement-bar__content p {
      margin: 0;
    }

    #shopify-section-{{ section.id }}-announcement-bar .announcement-bar__content a {
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    #shopify-section-{{ section.id }}-announcement-bar .announcement-bar__arrow {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      flex: 0 0 auto;
      width: 24px;
      height: 24px;
      padding: 0;
      background: transparent;
      border: 0;
      color: var(--announcement-bar-foreground);
      cursor: pointer;
    }

    #shopify-section-{{ section.id }}-announcement-bar .announcement-bar__arrow svg {
      width: var(--announcement-bar-arrow-size-mobile);
      height: var(--announcement-bar-arrow-size-mobile);
    }

    @media (min-width: 990px) {
      #shopify-section-{{ section.id }}-announcement-bar .announcement-bar__inner {
        gap: 16px;
        min-height: var(--announcement-bar-height-desktop);
        padding: 8px 24px;
      }

      #shopify-section-{{ section.id }}-announcement-bar .announcement-bar__content {
        font-size: var(--announcement-bar-font-size-desktop);
      }

      #shopify-section-{{ section.id }}-announcement-bar .announcement-bar__arrow svg {
        width: var(--announcement-bar-arrow-size-desktop);
        height: var(--announcement-bar-arrow-size-desktop);
      }
    }
  </style>

  {%- if show_arrows -%}
    <script>
      window.switchOnDOMContentLoaded(() => {
        const announcementBarSlider = document.getElementById('announcement-bar-slider-{{ section.id }}');
        if (announcementBarSlider) {
          window.makeSlideshow(announcementBarSlider);
        }
      });

      if (Shopify.designMode) {
        document.addEventListener('shopify:section:load', (event) => {
          if (event.target.querySelector('#announcement-bar-slider-{{ section.id }}')) {
            window.discoverNewSlideshows(event.target);
          }
        });
      }
    </script>
  {%- endif -%}
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "max_blocks": 5,
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "foreground_color",
      "label": "Text and arrow color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "arrow_weight",
      "min": 2,
      "max": 8,
      "step": 1,
      "label": "Arrow weight",
      "default": 5
    },
    {
      "type": "range",
      "id": "arrow_size_mobile",
      "min": 10,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Mobile arrow size",
      "default": 16
    },
    {
      "type": "range",
      "id": "arrow_size_desktop",
      "min": 10,
      "max": 36,
      "step": 1,
      "unit": "px",
      "label": "Desktop arrow size",
      "default": 16
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "default": "600",
      "options": [
        { "value": "400", "label": "Regular 400" },
        { "value": "500", "label": "Medium 500" },
        { "value": "600", "label": "Semibold 600" },
        { "value": "700", "label": "Bold 700" },
        { "value": "800", "label": "Extra bold 800" }
      ]
    },
    {
      "type": "range",
      "id": "bar_height_mobile",
      "min": 32,
      "max": 80,
      "step": 1,
      "unit": "px",
      "label": "Mobile bar height",
      "default": 44
    },
    {
      "type": "range",
      "id": "bar_height_desktop",
      "min": 32,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Desktop bar height",
      "default": 48
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Mobile font size",
      "default": 14
    },
    {
      "type": "range",
      "id": "font_size_desktop",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Desktop font size",
      "default": 16
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "Auto slide announcements",
      "default": true
    },
    {
      "type": "range",
      "id": "auto_rotate_interval",
      "min": 2,
      "max": 12,
      "step": 1,
      "unit": "s",
      "label": "Seconds between auto slides",
      "default": 4
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Add announcement text here.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement bar",
      "blocks": [
        { "type": "slide" }
      ]
    }
  ],
  "enabled_on": {
    "groups": [
      "header"
    ]
  }
}
{% endschema %}
